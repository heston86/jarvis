{
  "name": "jarvis",
  "version": "0.1.0",
  "description": "Jarvis Personal AI Assistant",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:ui\" \"npm run dev:electron\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:ui": "esbuild src/index.tsx --bundle --outfile=dist/renderer.js --sourcemap --watch",
    "dev:electron": "sleep 3 && electron .",
    "build": "npm run build:ui && npm run build:electron && npm run build:server",
    "build:ui": "esbuild src/index.tsx --bundle --outfile=dist/renderer.js --minify",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "electron .",
    "clean": "rm -rf dist tmp release",
    "pack": "npm run build && electron-builder --mac --dir",
    "dist": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@azure/msal-node": "^5.1.3",
    "@picovoice/porcupine-node": "^3.0.0",
    "@types/ws": "^8.18.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "electron-store": "^8.2.0",
    "express": "^4.21.0",
    "fish-audio": "^0.1.0",
    "googleapis": "^171.4.0",
    "node-fetch": "^3.3.2",
    "openwakeword-js": "^0.1.27",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.21.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5"
  },
  "build": {
    "appId": "com.heston.jarvis",
    "productName": "Jarvis",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ]
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "node_modules/**/*",
      ".env"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "directories": {
      "output": "release"
    },
    "asar": false
  }
}
