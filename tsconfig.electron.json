{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "outDir": "dist/electron",
    "rootDir": "electron",
    "lib": ["ES2022", "DOM"]
  },
  "include": ["electron/**/*"]
}
